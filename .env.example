# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── LLM Provider (Together AI is primary; Groq is fallback/moderation) ───────
# Together AI — primary Q&A (Llama 3.3 70B, pay-as-you-go)
# Get key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_key_here
# Override default model (optional — default: meta-llama/Llama-3.3-70B-Instruct-Turbo)
# LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Groq — optional fallback if TOGETHER_API_KEY is not set
# Also used for Wisdom Wall moderation if GROQ_MODERATION_KEY is set
# GROQ_API_KEY=gsk_your_key_here

# Wisdom Wall moderation — uses Together AI automatically if TOGETHER_API_KEY is set.
# Set this only if you want a dedicated Groq key for moderation instead.
# GROQ_MODERATION_KEY=
# Override moderation model (optional — default: meta-llama/Llama-3.2-3B-Instruct-Turbo)
# MOD_MODEL=meta-llama/Llama-3.2-3B-Instruct-Turbo

# ── Quotas ────────────────────────────────────────────────────────────────────
# Global org-wide daily query cap across all users (default: 15400)
# Set 0 to disable. Tune per deployment based on Together AI billing budget.
# GLOBAL_DAILY_LIMIT=15400

# ── Cron ─────────────────────────────────────────────────────────────────────
# Required in production to protect POST /api/wisdom/cron/maintenance
# Set to any random string; pass as X-Cron-Secret header in your cron scheduler
CRON_SECRET=

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:6333
# Production: your Qdrant Cloud URL
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── LangFuse (observability) ──────────────────────────────────────────────────
# Free Hobby tier — get keys at https://langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from https://supabase.com dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ_your_key_here

# ── Embedding model ───────────────────────────────────────────────────────────
# LOCKED to BAAI/bge-m3 in production (1024 dims, multilingual, handles Sanskrit)
# dev-only alternative: all-MiniLM-L6-v2 (fast, 384 dims — pipeline validation only)
EMBED_MODEL=BAAI/bge-m3

# BGE-M3 memory mode — set true on Apple Silicon / GPU (FP16 ~1GB vs FP32 ~2GB)
# Default is false (safe for CPU-only). Controls runtime + ingestion scripts.
BGE_FP16=false

# ── Dev helpers ───────────────────────────────────────────────────────────────
# Disable rate limiting for local load testing (never set in production)
# DISABLE_RATE_LIMIT=true
