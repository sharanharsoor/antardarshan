# Copy this to .env and fill in your values
# NEVER commit .env to git

# Groq — main Q&A (paid tier recommended, Llama 4 Scout 17B)
GROQ_API_KEY=gsk_your_key_here
# Groq — Wisdom Wall moderation (free tier Llama 8B, separate key)
# Falls back to GROQ_API_KEY if not set. Create a second key at console.groq.com before prod.
GROQ_MODERATION_KEY=

# Cron secret — required in production to protect POST /api/wisdom/cron/maintenance
# Set to any random string, pass as X-Cron-Secret header in your cron scheduler
CRON_SECRET=

# Qdrant (local dev: http://localhost:6333, prod: your Qdrant Cloud URL)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# LangFuse (free Hobby tier — get keys at langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Supabase Auth (free tier — get from supabase.com dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ_your_key_here

# BGE-M3 memory mode — set true on Apple Silicon / GPU to halve RAM (FP16 ~1GB vs FP32 ~2GB)
# Default is false (safe for CPU-only). Controls runtime + ingestion scripts.
BGE_FP16=false

# Disable rate limiting for local load testing (never set in production)
# DISABLE_RATE_LIMIT=true

# Embedding model — MUST be the same for indexing and querying
# dev-only: all-MiniLM-L6-v2 (fast, 384 dims, pipeline validation only)
# production (LOCKED): BAAI/bge-m3 (1024 dims, multilingual, handles Sanskrit)
# Decision: bge-m3 is the production default from Phase 2 onward. MiniLM is dev-only.
EMBED_MODEL=BAAI/bge-m3
