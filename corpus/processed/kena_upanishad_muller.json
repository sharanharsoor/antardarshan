    "verse_type": "verse",
    "chunk_id": "21770ddd98e36097"
  },
  {
    "text": "'That which does not breathe by breath, and by which breath is drawn, that alone know as Brahman, not that which people here adore.",
    "scripture": "Kena Upanishad",
    "tradition": "hindu_vedanta",
    "chapter": 1,
    "verse": 9,
    "translator": "Max Müller",
    "year": 1879,
