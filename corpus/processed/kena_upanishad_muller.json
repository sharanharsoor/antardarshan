    "speaker": null,
    "chapter_name": null,
    "commentary_source": null,
    "chunk_type": "verse",
    "verse_type": "verse",
    "chunk_id": "cc03cfd692429fb9"
  },
  {
    "text": "'That which does not think by mind, and by which, they say, mind is thought, that alone know as Brahman, not that which people here adore.",
    "scripture": "Kena Upanishad",
    "tradition": "hindu_vedanta",
    "chapter": 1,
    "verse": 6,
    "translator": "Max Müller",
    "year": 1879,
    "language": "en",
    "license_tier": "A",
