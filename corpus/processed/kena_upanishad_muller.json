    "chapter_name": null,
    "commentary_source": null,
    "chunk_type": "verse",
    "verse_type": "verse",
    "chunk_id": "f97e743394a57df4"
  },
  {
    "text": "'That which does not see by the eye, and by which one sees the work of the eyes, that alone know as Brahman, not that which people here adore.",
    "scripture": "Kena Upanishad",
    "tradition": "hindu_vedanta",
