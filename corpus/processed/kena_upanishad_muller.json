    "verse_type": "verse",
    "chunk_id": "412367f1072063f5"
  },
  {
    "text": "'That which does not hear by the ear, and by which the ear is heard, that alone know as Brahman, not that which people here adore.",
    "scripture": "Kena Upanishad",
    "tradition": "hindu_vedanta",
    "chapter": 1,
    "verse": 8,
