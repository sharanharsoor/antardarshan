  },
  {
    "text": "The waking state, outwardly cognitive, having seven limbs, having nineteen mouths, enjoying the gross, the Vaishvanara, is the first quarter (foot).",
    "scripture": "Mandukya Upanishad",
    "tradition": "hindu_vedanta",
    "chapter": 1,
    "verse": 3,
    "translator": "Max Müller",
    "year": 1884,
