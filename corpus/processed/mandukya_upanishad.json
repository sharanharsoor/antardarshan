    "verse_type": "verse",
    "chunk_id": "d019b10c6d7fea75"
  },
  {
    "text": "The dreaming state, inwardly cognitive, having seven limbs, having nineteen mouths, enjoying the exquisite, the Taijasa, is the second quarter.",
    "scripture": "Mandukya Upanishad",
    "tradition": "hindu_vedanta",
    "chapter": 1,
    "verse": 4,
    "translator": "Max Müller",
    "year": 1884,
